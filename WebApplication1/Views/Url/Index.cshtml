@model IEnumerable<WebApplication1.Models.Url>

<h2>URL Shortener</h2>

<form method="post" asp-action="Create">
    <input type="text" name="originalUrl" placeholder="Enter URL" />
    <button type="submit">Shorten</button>
</form>

<table class="table" border="1">
    <tr>
        <th>Long URL</th>
        <th>Short URL</th>
        <th>Date</th>
        <th>Clicks</th>
        <th>Actions</th>
    </tr>

    @foreach (var item in Model)
    {
        <tr>
            <td>@item.OriginalUrl</td>
            <td>
                <a href="/@item.ShortCode">
                    @Context.Request.Scheme://@Context.Request.Host/@item.ShortCode
                </a>
            </td>
            <td>@item.CreatedAt</td>
            <td>@item.ClickCount</td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-primary btn-sm">Edit</a>
                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm" onclick="return confirm('Delete?');">Delete</a>
            </td>
        </tr>
    }
</table>